# Database
POSTGRES_DB=people_intel
POSTGRES_USER=pi_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://pi_user:CHANGE_ME_strong_password_here@postgres:5432/people_intel
REDIS_URL=redis://redis:6379/0

# LLM providers (fill in the ones you use)
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# Scraping
APIFY_API_TOKEN=

# LLM config
LLM_PROVIDER=gemini
LLM_MODEL_GEMINI=gemini-2.5-flash-lite
PROMPT_VERSION=v4

# CORS — set to your actual domain or IP
CORS_ORIGINS=http://195.201.29.199

# QA thresholds (optional overrides)
QA_MAX_L1_CATEGORIES=4
QA_MAX_DECLARED_CAPABILITIES=8
QA_MAX_INFERRED=5
QA_MAX_TOPICS=20