# Required — powers the AI scraping agent
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM for expertise analysis (pick one)
LLM_PROVIDER=gemini          # claude, openai, or gemini
GOOGLE_API_KEY=               # Required if LLM_PROVIDER=gemini
OPENAI_API_KEY=               # Required if LLM_PROVIDER=openai

# LinkedIn enrichment via Apify
APIFY_API_TOKEN=your-apify-token

# Optional: proxy services
SCRAPEDO_API_KEY=
PROXY_URLS=                   # Comma-separated proxy URLs