# Required
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: OpenAI for expertise analysis (set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=your-openai-api-key
LLM_PROVIDER=claude

# Optional: Apify for LinkedIn enrichment
APIFY_API_TOKEN=your-apify-token

# Optional: Proxy URLs (comma-separated)
PROXY_URLS=
